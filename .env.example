# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/hockey-app?retryWrites=true&w=majority
DB_NAME=hockey-app

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=<your-32-byte-hex-secret>

# ── App URL (used in email links) ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Obtain from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Sender address — must be a verified domain in your Resend account
EMAIL_FROM=Hockey App <noreply@yourdomain.com>

# ── Payments ───────────────────────────────────────────────────────────────────
# Controls which payment path the /api/checkout route uses.
#   simulate  — instant DB writes with no real money movement (default in dev)
#   stripe    — real Stripe Checkout (requires keys below)
#   none      — online payment disabled; registrars record payment manually
PAYMENT_GATEWAY_MODE=simulate

# ── Stripe (required when PAYMENT_GATEWAY_MODE=stripe) ────────────────────────
# Obtain from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint
# For local testing: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
