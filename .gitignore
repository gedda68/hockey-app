# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/scripts
!/scripts
/scripts/*
!/scripts/clean-dynamic-slug-conflicts.mjs

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.claude/worktrees/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local

# stale backup files
*.old
*.zip
*copy*.ts
*Copy*.ts
# Exceptions — production source files that legitimately contain "Copy" in the name
!lib/website/associationHubCopy.ts